{
  "AIProvider": {
    "Provider": "Gemini",
    "DefaultModel": "gemini-2.5-flash",
    "HistoryLimit": 10
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=Chatbot;Username=postgres;Password=postgres"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:4300"
    ]
  },
  "AllowedHosts": "*"
}
