{
  "AIProvider": {
    "Provider": "Gemini",
    "DefaultModel": "gemini-2.5-flash-lite",
    "HistoryLimit": 10
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434"
  },
  "Gemini": {
    "ApiKey": "",
    "EmbeddingModel": "gemini-embedding-001",
    "EmbeddingApiVersion": "v1beta"
  },
  "RAG": {
    "Enabled": true,
    "ChunkSize": 500,
    "ChunkOverlap": 50,
    "TopK": 3,
    "SimilarityThreshold": 0.0
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=Chatbot;Username=postgres;Password=postgres"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:4300",
      "http://localhost:5005",
      "http://localhost:61182"
    ]
  },
  "AllowedHosts": "*"
}
